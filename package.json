{
  "name": "hodu-timer",
  "version": "1.0.0",
  "description": "Pomodoro Timer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.hodu.timer",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "dist_native"
    },
"win": {
  "icon": "tomato.ico",
  "target": [
    {
      "target": "dir",
      "arch": ["x64"]
    }
  ]
},
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1"
  }
}
