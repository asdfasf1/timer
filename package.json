{
  "name": "pomodoro-app",
  "version": "1.0.0",
  "description": "Vibe Coding Pomodoro Timer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.vibecoding.pomodoro",
    "compression": "store",
    "asar": false,
    "directories": {
      "output": "dist_native"
    },
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1"
  }
}
